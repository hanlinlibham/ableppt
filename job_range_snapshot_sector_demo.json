{
  "mode": "composer",
  "theme": "jp_finance",
  "datasources": {
    "sector_valuation": {
      "type": "csv",
      "path": "data/range_snapshot_sector_valuation.csv"
    }
  },
  "pages": [
    {
      "layout": "range_snapshot",
      "data": {
        "title": "S&P 500 valuation",
        "subtitle": "Forward price-to-earnings ratio",
        "insight": "Two sectors carry the valuation outliers, so the page uses a segmented axis to preserve readability for the rest of the sector stack.",
        "source": "sector_valuation",
        "categories_col": "sector",
        "min_col": "range_min",
        "max_col": "range_max",
        "average_col": "average",
        "current_col": "current",
        "orientation": "vertical",
        "range_color": "5F6772",
        "average_color": "87A330",
        "current_color": "1E88E5",
        "number_format": "0.0x",
        "show_average_ticks": true,
        "show_current_markers": true,
        "show_current_labels": true,
        "axis_break": {
          "value": 30.0,
          "compress_ratio": 0.22,
          "tick_values": [0, 5, 10, 15, 20, 25, 30, 50],
          "categories": ["Energy", "Info Tech"]
        },
        "footnote": "Illustrative vertical sector valuation demo"
      }
    }
  ],
  "output": {
    "path": "range_snapshot_sector_composer_demo.pptx"
  }
}
