{
  "mode": "composer",
  "theme": "dashboard_shell_16_9",
  "aspect_ratio": "16:9",
  "datasources": {
    "hs300_close_amount": {"type": "csv", "path": "data/market_gallery/hs300_close_amount.csv"},
    "hs300_close_vol": {"type": "csv", "path": "data/market_gallery/hs300_close_vol.csv"},
    "hs300_close_cumret": {"type": "csv", "path": "data/market_gallery/hs300_close_cumret.csv"},
    "moutai_price_turnover": {"type": "csv", "path": "data/market_gallery/moutai_price_turnover.csv"},
    "moutai_price_pe": {"type": "csv", "path": "data/market_gallery/moutai_price_pe.csv"},
    "valuation_dual": {"type": "csv", "path": "data/market_gallery/valuation_dual.csv"},
    "index_summary": {"type": "csv", "path": "data/market_gallery/index_summary.csv"}
  },
  "pages": [
    {
      "layout": "dashboard_shell_16_9",
      "data": {
        "title": "沪深300指数点位与成交额",
        "insight": "用一个最典型的双轴图先校准 bar+line 的层次、左右轴刻度和 legend 间距。",
        "section": "Dual Axis Gallery",
        "page_label": "01",
        "source": "Source: Tushare -> SQLite cache",
        "body": {
          "family": "performance_compare",
          "source": "hs300_close_amount",
          "categories_col": "日期",
          "series": [
            {"key": "成交额(万亿元)", "name": "成交额(右轴, 万亿元)", "role": "benchmark", "type": "bar", "axis": "secondary"},
            {"key": "指数点位", "name": "指数点位(左轴)", "role": "fund", "type": "line", "axis": "primary"}
          ],
          "number_format": "#,##0",
          "secondary_number_format": "0.0",
          "secondary_axis_font_size_pt": 8,
          "line_width_pt": 1.5,
          "chart_title": "沪深300指数点位与成交额"
        }
      }
    },
    {
      "layout": "dashboard_shell_16_9",
      "data": {
        "title": "股票估值与市值双轴",
        "insight": "横截面双轴图适合用来调柱形宽度、右轴范围和品种名称密度。",
        "section": "Dual Axis Gallery",
        "page_label": "02",
        "source": "Source: Tushare -> SQLite cache",
        "body": {
          "family": "performance_compare",
          "source": "valuation_dual",
          "categories_col": "股票",
          "series": [
            {"key": "总市值(万亿元)", "name": "总市值(右轴, 万亿元)", "role": "benchmark", "type": "bar", "axis": "secondary"},
            {"key": "PE", "name": "PE(左轴)", "role": "fund", "type": "line", "axis": "primary"},
            {"key": "PB", "name": "PB(左轴)", "role": "peer", "type": "line", "axis": "primary"}
          ],
          "number_format": "0.0",
          "secondary_number_format": "0.0",
          "secondary_axis_font_size_pt": 8,
          "line_width_pt": 1.5,
          "chart_title": "股票估值与市值双轴"
        }
      }
    },
    {
      "layout": "dashboard_shell_16_9",
      "data": {
        "title": "指数点位与波动率",
        "insight": "area + line 的经典双轴结构，适合调面积透明度和右轴波动率的阅读性。",
        "section": "Dual Axis Gallery",
        "page_label": "04",
        "source": "Source: Tushare -> SQLite cache",
        "body": {
          "family": "performance_compare",
          "source": "hs300_close_vol",
          "categories_col": "日期",
          "series": [
            {"key": "波动率", "name": "21日年化波动率(右轴)", "role": "benchmark", "type": "area", "axis": "secondary"},
            {"key": "指数点位", "name": "指数点位(左轴)", "role": "fund", "type": "line", "axis": "primary"}
          ],
          "number_format": "#,##0",
          "secondary_number_format": "0.0%",
          "secondary_axis_font_size_pt": 8,
          "line_width_pt": 1.5,
          "chart_title": "指数点位与波动率"
        }
      }
    },
    {
      "layout": "dashboard_shell_16_9",
      "data": {
        "title": "指数点位与累计收益率",
        "insight": "双折线双轴页，用于比较左右轴都是连续变量时的视觉平衡。",
        "section": "Dual Axis Gallery",
        "page_label": "05",
        "source": "Source: Tushare -> SQLite cache",
        "body": {
          "family": "performance_compare",
          "source": "hs300_close_cumret",
          "categories_col": "日期",
          "series": [
            {"key": "累计收益率", "name": "累计收益率(右轴)", "role": "benchmark", "type": "line", "axis": "secondary"},
            {"key": "指数点位", "name": "指数点位(左轴)", "role": "fund", "type": "line", "axis": "primary"}
          ],
          "number_format": "#,##0",
          "secondary_number_format": "0.0%",
          "secondary_axis_font_size_pt": 8,
          "line_width_pt": 1.5,
          "chart_title": "指数点位与累计收益率"
        }
      }
    },
    {
      "layout": "dashboard_shell_16_9",
      "data": {
        "title": "茅台收盘价与换手率",
        "insight": "个股 time-series 的双轴 bar+line 组合，适合调金融资产页的节奏感。",
        "section": "Dual Axis Gallery",
        "page_label": "06",
        "source": "Source: Tushare -> SQLite cache",
        "body": {
          "family": "performance_compare",
          "source": "moutai_price_turnover",
          "categories_col": "日期",
          "series": [
            {"key": "换手率", "name": "换手率(右轴)", "role": "benchmark", "type": "bar", "axis": "secondary"},
            {"key": "收盘价", "name": "收盘价(左轴)", "role": "fund", "type": "line", "axis": "primary"}
          ],
          "number_format": "#,##0.0",
          "secondary_number_format": "0.0",
          "secondary_axis_font_size_pt": 8,
          "line_width_pt": 1.5,
          "chart_title": "茅台收盘价与换手率"
        }
      }
    },
    {
      "layout": "dashboard_shell_16_9",
      "data": {
        "title": "茅台收盘价与PE",
        "insight": "双折线双轴个股页，适合看估值和价格的同步/背离关系。",
        "section": "Dual Axis Gallery",
        "page_label": "07",
        "source": "Source: Tushare -> SQLite cache",
        "body": {
          "family": "performance_compare",
          "source": "moutai_price_pe",
          "categories_col": "日期",
          "series": [
            {"key": "PE", "name": "PE(右轴)", "role": "benchmark", "type": "line", "axis": "secondary"},
            {"key": "收盘价", "name": "收盘价(左轴)", "role": "fund", "type": "line", "axis": "primary"}
          ],
          "number_format": "#,##0.0",
          "secondary_number_format": "0.0",
          "secondary_axis_font_size_pt": 8,
          "line_width_pt": 1.5,
          "chart_title": "茅台收盘价与PE"
        }
      }
    },
    {
      "layout": "dashboard_shell_16_9",
      "data": {
        "title": "年化收益与波动双轴",
        "insight": "把收益和波动叠在一张图里，更容易看双轴样式是否平衡。",
        "section": "Dual Axis Gallery",
        "page_label": "08",
        "source": "Source: Tushare -> SQLite cache",
        "body": {
          "family": "performance_compare",
          "source": "index_summary",
          "categories_col": "指数",
          "series": [
            {"key": "年化波动率", "name": "年化波动率(右轴)", "role": "benchmark", "type": "bar", "axis": "secondary"},
            {"key": "年化收益率", "name": "年化收益率(左轴)", "role": "fund", "type": "line", "axis": "primary"}
          ],
          "number_format": "0.0%",
          "line_width_pt": 1.5,
          "chart_title": "年化收益与波动双轴"
        }
      }
    }
  ],
  "output": {"path": "dual_axis_gallery_demo.pptx"}
}
