                "theme": "gtm",
                "line_width": 1.5
              },
              "layout": {
                "legend": "bottom",
                "y_axis": {
                  "format": "0%"
                }
              },
              "annotations": [
                {
                  "type": "band",
                  "from": 0.02,
                  "to": 0.03,
                  "label": "目标区间"
                }
              ]
            },
            "table": {
              "columns": [
                "",
                "均值",
                "最新"
              ],
              "rows": [
                [
                  "CPI同比",
                  "2.1%",
                  "2.4%"
                ],
                [
                  "核心CPI",
                  "1.9%",
                  "2.1%"
                ]
              ],
              "row_colors": [
                "#29ABE2",
                "#595959"
              ],
              "at": [
                0.42,
                0.03
              ],
              "width": 2.1
            }
          },
          {
            "title": "通胀分项贡献",
            "subtitle": "同比，百分点",
            "chart": {
              "chart": "contribution",
