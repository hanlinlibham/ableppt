      }
    },
    {
      "layout": "gtm_toc",
      "data": {
        "title": "目录"
      }
    },
    {
      "layout": "gtm_panels",
      "data": {
        "title": "经济增长与GDP构成",
        "section": "宏观",
        "source": "来源：国家统计局，Wind，PPT·FI 计算。趋势增速基于 2012 年以来季度实际 GDP 拟合。Guide to the Markets 风格演示，数据为拟真样例。",
        "panels": [
          {
            "title": "实际GDP",
            "subtitle": "同比增速的贡献分解，百分点",
            "chart": {
              "chart": "contribution",
              "data": "data/gtm/gdp_contrib.csv",
              "total": "GDP同比",
              "layout": {
                "legend": "bottom",
                "y_axis": {
                  "format": "0%"
                }
              }
            }
          },
          {
            "title": "实际GDP趋势",
            "subtitle": "指数，2012=60",
            "chart": {
              "chart": "line",
              "data": "data/gtm/gdp_trend.csv",
              "legend": "none",
              "style": {
                "colors": [
                  "#595959",
                  "#29ABE2"
                ]
              },
              "series": [
                {
                  "column": "实际GDP指数",
                  "line_width": 1.75,
                  "last_point_label": {
                    "format": "#,##0"
                  }
                },
                {
                  "column": "趋势线",
                  "line_width": 1.25
                }
              ]
            },
            "table": {
              "columns": [
                "GDP (%)",
                "3Q24",
                "4Q24",
                "1Q25",
                "2Q25"
              ],
              "rows": [
                [
                  "环比",
                  "0.3",
                  "0.6",
                  "0.3",
                  "0.6"
                ],
                [
                  "同比",
                  "0.8",
                  "1.3",
                  "1.4",
                  "1.8"
                ]
              ],
              "at": [
                0.05,
                0.04
              ],
              "width": 2.6
            }
          }
        ]
      }
    },
    {
      "layout": "gtm_panels",
      "data": {
        "title": "通货膨胀",
        "section": "宏观",
        "source": "来源：国家统计局，Wind，PPT·FI 计算。核心CPI为剔除食品和能源的CPI。演示数据。",
        "panels": [
          {
            "title": "CPI与核心CPI",
            "subtitle": "同比",
            "chart": {
              "chart": "line",
