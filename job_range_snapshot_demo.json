{
  "mode": "composer",
  "theme": "jp_finance",
  "datasources": {
    "valuation": {
      "type": "csv",
      "path": "data/range_snapshot_valuation.csv"
    }
  },
  "pages": [
    {
      "layout": "range_snapshot",
      "data": {
        "title": "Global valuations",
        "subtitle": "Current and historical price-to-earning valuations",
        "insight": "This page encodes each market's historical range as a floating band, then layers its long-run average and current reading as semantic overlays.",
        "source": "valuation",
        "categories_col": "market",
        "min_col": "range_min",
        "max_col": "range_max",
        "average_col": "average",
        "current_col": "current",
        "orientation": "horizontal",
        "range_color": "5F6772",
        "average_color": "87A330",
        "current_color": "1E88E5",
        "number_format": "0.0x",
        "show_average_ticks": true,
        "show_current_markers": true,
        "show_current_labels": true,
        "axis_break": {
          "value": 30.0,
          "categories": ["Japan"]
        },
        "footnote": "Illustrative valuation range snapshot demo"
      }
    }
  ],
  "output": {
    "path": "range_snapshot_composer_demo.pptx"
  }
}
